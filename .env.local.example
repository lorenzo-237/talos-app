# Copier ce fichier en .env.local et remplir les valeurs

# Répertoire contenant les ressources sources (wdlls/, dlls/, directories/, files/, install/)
SRC_DIR=C:/adsion/src

# Répertoire de sortie des archives générées
OUTPUT_DIR=C:/adsion/output

# Répertoire contenant les dossiers de packages JSON (ex: packages/3.3.3/*.json)
PACKAGES_DIR=C:/adsion/packages
